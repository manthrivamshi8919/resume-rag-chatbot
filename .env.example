# Server
PORT=8000
CORS_ORIGINS=*

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=resume-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Embeddings (local)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# OpenRouter (LLM)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=resume-rag-chatbot

# Retrieval
TOP_K=5
MAX_CONTEXT_CHARS=12000
